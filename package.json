{
  "name": "bigbanana-ai-director",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check:utf8": "node scripts/check-utf8.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "build": "pnpm run check:utf8 && vite build",
    "preview": "vite preview",
    "media-proxy": "node server/mediaProxyServer.mjs",
    "lint": "eslint . --fix --ignore-pattern \".trae/**\"",
    "format": "prettier --ignore-path .prettierignore --write \"App.tsx\" \"index.tsx\" \"vite.config.ts\" \"global.d.ts\" \"components/**/*.{ts,tsx}\" \"services/**/*.{ts,tsx}\" \"hooks/**/*.{ts,tsx}\" \"types/**/*.ts\" \"types.ts\" \"styles/**/*.{css,scss}\" \"public/styles/**/*.css\"",
    "check:format": "prettier --ignore-path .prettierignore --check \"App.tsx\" \"index.tsx\" \"vite.config.ts\" \"global.d.ts\" \"components/**/*.{ts,tsx}\" \"services/**/*.{ts,tsx}\" \"hooks/**/*.{ts,tsx}\" \"types/**/*.ts\" \"types.ts\" \"styles/**/*.{css,scss}\" \"public/styles/**/*.css\"",
    "check:code": "pnpm run lint && pnpm run check:format",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --fix",
    "*.{js,jsx,ts,tsx,json,css,scss,md}": "prettier --write"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-mention": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@volcengine/tos-sdk": "^2.9.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "postcss": "^8.5.9",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.2.0"
  }
}
